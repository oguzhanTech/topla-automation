# Topla internal API (no trailing slash on base URL)
TOPLA_API_BASE_URL=https://www.topla.online
TOPLA_IMPORT_API_KEY=your-secret-import-key

# Logical bot identity — must match a key in deal-radar TOPLA_IMPORT_ACTOR_MAP (or allowlist)
TOPLA_ACTOR_KEY=topla_trendyol_bot

# Comma-separated scrapers: amazon, trendyol (default: amazon)
INGESTION_SOURCES=amazon
# Product or listing page recommended for Amazon (homepage works but yields sparse data)
AMAZON_START_URL=https://www.amazon.com.tr/

# Browser
HEADLESS=true
BROWSER=chrome

# Selenium timeouts (ms)
PAGE_LOAD_TIMEOUT_MS=30000
IMPLICIT_WAIT_MS=5000

# API client
API_RETRY_COUNT=3
API_RETRY_DELAY_MS=1000
API_CONNECT_TIMEOUT_MS=10000
API_REQUEST_TIMEOUT_MS=30000
