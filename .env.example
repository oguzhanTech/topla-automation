# Bu dosyayı kopyalayıp .env olarak kaydedin; jar yalnızca .env okur (.env.example otomatik yüklenmez).
# copy .env.example .env   (PowerShell: Copy-Item .env.example .env)

# Topla dahili API (base URL sonunda / olmasın)
TOPLA_API_BASE_URL=https://www.topla.online
TOPLA_IMPORT_API_KEY=your-secret-import-key

# Mantıksal bot kimliği — deal-radar TOPLA_IMPORT_ACTOR_MAP içindeki anahtarla aynı olmalı (yalnızca metin, UUID değil)
TOPLA_ACTOR_KEY=topla_trendyol_bot

# Virgülle ayrılmış kaynaklar: amazon, trendyol (varsayılan: amazon)
INGESTION_SOURCES=amazon

# İsteğe bağlı: her importta sabit kategori (Topla'da kullandığınız kategori adıyla uyumlu)
# DEAL_CATEGORY=Elektronik

# true ise import metadata JSON gönderir (deal-radar açıklamaya [import] altında ekleyebilir). Varsayılan: false
# TOPLA_IMPORT_SEND_METADATA=false

# Amazon modu: urls = AMAZON_URLS / AMAZON_START_URL (doğrudan ürün sayfaları)
#              hub = AMAZON_DEALS_HUB_URL aç, indirimli linkleri topla, en fazla AMAZON_DEALS_TARGET_COUNT ürün detayı çek
AMAZON_MODE=urls
# AMAZON_MODE=hub
# AMAZON_DEALS_HUB_URL=https://www.amazon.com.tr/deals
# AMAZON_DEALS_TARGET_COUNT=3
# AMAZON_DEALS_RANDOM_SEED=42

# Tek Amazon sayfası (urls modu; AMAZON_URLS yoksa kullanılır)
AMAZON_START_URL=https://www.amazon.com.tr/
# Birden çok ürün URL'si → urls modunda bir koşuda her URL için bir deal
# AMAZON_URLS=https://www.amazon.com.tr/dp/URUN1,https://www.amazon.com.tr/dp/URUN2

# Tarayıcı
HEADLESS=true
BROWSER=chrome

# Selenium zaman aşımları (ms)
PAGE_LOAD_TIMEOUT_MS=30000
IMPLICIT_WAIT_MS=5000

# API istemcisi
API_RETRY_COUNT=3
API_RETRY_DELAY_MS=1000
API_CONNECT_TIMEOUT_MS=10000
API_REQUEST_TIMEOUT_MS=30000
